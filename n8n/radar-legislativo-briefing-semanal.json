    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet html = \"<h2>Radar Legislativo — Briefing Semanal</h2>\";\n\nfor (const item of items) {\n  const d = item.json;\n  const data = d.dataApresentacao.substring(0, 10);\n  html += `<h3>${d.tema}</h3>`;\n  html += `<p><strong>${d.siglaTipo} ${d.numero}</strong> — ${data}</p>`;\n  html += `<p>${d.resumo}</p><hr>`;\n}\n\nhtml += '<p style=\"margin-top:24px\"><a href=\"https://radar-legislativo.streamlit.app\" style=\"background:#1e3a5f;color:#fff;padding:10px 20px;text-decoration:none;border-radius:4px\">Ver dashboard completo →</a></p>';\n\nreturn [{ json: { html } }];"
      },
