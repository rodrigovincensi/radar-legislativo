        "query": "SELECT DISTINCT ON (tema) tema, \"siglaTipo\", numero, \"dataApresentacao\", ementa, resumo\nFROM proposicoes\nWHERE resumo IS NOT NULL\n  AND tema IS NOT NULL\n  AND \"siglaTipo\" IN ('PL', 'PEC', 'PLP', 'MPV', 'PDL')\nORDER BY tema, \"dataApresentacao\" DESC",
